# claude-proxy environment variables
# Copy to .env and fill in values, or export them directly in your shell.
# Never commit real credentials — all values here are intentionally blank.

# API key for the Anthropic passthrough profile
ANTHROPIC_API_KEY=

# Upstream Anthropic API base URL (override to point at a local mirror)
UPSTREAM_BASE_URL=

# Seconds to wait for an upstream response before timing out
UPSTREAM_READ_TIMEOUT=

# Host and port for the proxy server (overridden by config.toml [server] if present)
CCPROXY_HOST=
CCPROXY_PORT=

# Active profile name — overrides ccswitch state.json default
CCPROXY_PROFILE=

# OpenAI-compatible API base URL (for the openai profile)
OPENAI_BASE_URL=

# OpenAI-compatible API key (for the openai profile)
OPENAI_API_KEY=

# OpenAI model name forwarded upstream (for the openai profile)
OPENAI_MODEL=

# Tool call mode in OpenAI mode: native (function calling) or xml (prompt injection)
CCPROXY_TOOL_MODE=

# Extended-thinking handling on the OpenAI path:
#   disabled (default) — force thinking off so the upstream never enables it
#                        with a budget that can exceed max_tokens (avoids HTTP 400)
#   forward            — pass the client's thinking block through unchanged
#   strip              — send no thinking field (for upstreams that reject it)
OPENAI_THINKING_MODE=

# Path for the per-request JSONL log file
CCPROXY_LOG_FILE=

# Rolling window in seconds for GET /metrics (omit to accumulate all-time)
METRICS_WINDOW_SECONDS=
